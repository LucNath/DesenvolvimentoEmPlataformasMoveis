<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="@color/bg_card">

    <!-- Capa do livro -->
    <ImageView
        android:id="@+id/ivCover"
        android:layout_width="48dp"
        android:layout_height="64dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_cover_placeholder"
        android:layout_marginEnd="12dp" />

    <!-- Título + Autor + Vencimento -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvAuthor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvDueDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/brand_orange"
            android:layout_marginTop="6dp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Botões de Ação -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="8dp">

        <Button
            android:id="@+id/btnRenovar"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Renovar"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:background="@drawable/bg_button_orange"
            android:stateListAnimator="@null"
            android:visibility="gone"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnVer"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Ver"
            android:textSize="11sp"
            android:textColor="@color/text_primary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@drawable/bg_button_outline_white"
            android:stateListAnimator="@null" />
    </LinearLayout>

</LinearLayout>