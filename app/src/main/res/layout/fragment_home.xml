<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Azul com Cantos Arredondados -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_header"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_greeting"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:alpha="0.9" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:text="Lucas Mendes"
                android:layout_marginTop="4dp" />

            <!-- Barra de Busca Customizada -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_search_white_tint">

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="parent"
                    android:background="@android:color/transparent"
                    android:hint="Buscar livros..."
                    android:textColorHint="#CCFFFFFF"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:paddingStart="48dp"
                    android:paddingEnd="16dp"
                    android:inputType="text"
                    android:drawableStart="@drawable/ic_search"
                    android:drawablePadding="12dp"
                    android:drawableTint="@color/white" />
            </FrameLayout>

        </LinearLayout>

        <!-- Conteúdo Principal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp">

            <!-- Estado Vazio -->
            <LinearLayout
                android:id="@+id/layoutEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="48dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_empty_books"
                    app:tint="@color/blue_royal" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:text="@string/empty_state_title"
                    android:textColor="@color/text_primary_light"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/empty_state_subtitle"
                    android:textColor="@color/text_secondary_light"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExploreCatalog"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:paddingHorizontal="32dp"
                    android:text="@string/btn_explore_catalog"
                    android:textAllCaps="false"
                    app:cornerRadius="24dp" />
            </LinearLayout>

            <!-- Seção: Empréstimos Ativos -->
            <RelativeLayout
                android:id="@+id/layoutLoansHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/loans_active_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_light"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:id="@+id/tvVerTodosEmprestimos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/view_all"
                    android:textSize="14sp"
                    android:textColor="@color/blue_royal"
                    android:textStyle="bold"
                    android:layout_alignParentEnd="true"
                    android:minHeight="48dp"
                    android:gravity="center" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLoans"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:layout_marginBottom="24dp" />

            <!-- Seção: Reservas -->
            <RelativeLayout
                android:id="@+id/layoutReservationsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/my_reservations_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_light"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:id="@+id/tvVerTodasReservas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/view_all"
                    android:textSize="14sp"
                    android:textColor="@color/blue_royal"
                    android:textStyle="bold"
                    android:layout_alignParentEnd="true"
                    android:minHeight="48dp"
                    android:gravity="center" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvReservations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:layout_marginBottom="24dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>