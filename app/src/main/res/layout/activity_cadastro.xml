<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="32dp"
        android:paddingTop="80dp"
        android:paddingBottom="40dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/logo"
            android:contentDescription="@string/content_desc_logo" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/register_title"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/register_subtitle"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <EditText
            android:id="@+id/etNome"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="48dp"
            android:hint="@string/name_hint"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:inputType="textPersonName"
            android:background="@drawable/input_background"
            android:paddingHorizontal="16dp" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:hint="@string/email_inst_hint"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:inputType="textEmailAddress"
            android:background="@drawable/input_background"
            android:paddingHorizontal="16dp" />

        <EditText
            android:id="@+id/etMatricula"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:hint="@string/matricula_hint"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:inputType="number"
            android:background="@drawable/input_background"
            android:paddingHorizontal="16dp" />

        <EditText
            android:id="@+id/etSenha"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:hint="@string/password_rules_hint"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:inputType="textPassword"
            android:background="@drawable/input_background"
            android:paddingHorizontal="16dp" />

        <EditText
            android:id="@+id/etConfirmarSenha"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:hint="@string/confirm_password_hint"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:inputType="textPassword"
            android:background="@drawable/input_background"
            android:paddingHorizontal="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCriarConta"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="@string/btn_create_account"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/orange_primary"
            app:cornerRadius="28dp" />

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/btn_already_have_account"
            android:textColor="@color/orange_primary"
            android:textSize="14sp"
            android:background="@drawable/button_outline"
            android:backgroundTint="@android:color/transparent" />

    </LinearLayout>

</ScrollView>