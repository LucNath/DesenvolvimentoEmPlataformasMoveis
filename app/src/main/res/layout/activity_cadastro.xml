<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="32dp"
        android:paddingTop="80dp"
        android:paddingBottom="40dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/logo"
            android:contentDescription="Logo" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Criar conta"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Acesse o acervo da biblioteca"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <EditText
            android:id="@+id/etNome"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="48dp"
            android:hint="Nome completo"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:inputType="textPersonName"
            android:background="@drawable/input_background"
            android:paddingHorizontal="16dp" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:hint="Email institucional"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:inputType="textEmailAddress"
            android:background="@drawable/input_background"
            android:paddingHorizontal="16dp" />

        <EditText
            android:id="@+id/etMatricula"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:hint="Matrícula"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:inputType="number"
            android:background="@drawable/input_background"
            android:paddingHorizontal="16dp" />

        <EditText
            android:id="@+id/etSenha"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:hint="Senha (mín. 8 caracteres)"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:inputType="textPassword"
            android:background="@drawable/input_background"
            android:paddingHorizontal="16dp" />

        <EditText
            android:id="@+id/etConfirmarSenha"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:hint="Confirmar senha"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:inputType="textPassword"
            android:background="@drawable/input_background"
            android:paddingHorizontal="16dp" />

        <Button
            android:id="@+id/btnCriarConta"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="Criar conta"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/orange_primary"
            android:cornerRadius="28dp" />

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Já tem uma conta? Login"
            android:textColor="@color/orange_primary"
            android:textSize="14sp"
            android:background="@drawable/button_outline"
            android:backgroundTint="@android:color/transparent" />

    </LinearLayout>

</ScrollView>