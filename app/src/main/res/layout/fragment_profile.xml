<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Azul -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_header"
            android:paddingBottom="32dp">

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_margin="24dp"
                android:background="@drawable/bg_search_white_tint"
                android:src="@android:drawable/ic_menu_preferences"
                android:padding="8dp"
                app:tint="@color/white"
                android:contentDescription="Configurações" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="60dp">

                <TextView
                    android:id="@+id/tvAvatar"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:background="@drawable/bg_cover_pill"
                    android:backgroundTint="#40FFFFFF"
                    android:gravity="center"
                    android:text="LM"
                    android:textColor="@color/white"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Lucas Mendes"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvUserCourse"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Aluno · Direito"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="-24dp">

            <!-- Estatísticas (Card Arredondado) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F3F4F6">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:id="@+id/tvBorrowed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2" android:textColor="@color/blue_royal" android:textSize="24sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/profile_borrowed" android:textColor="@color/text_secondary_light" android:textSize="12sp" />
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="40dp" android:background="#F3F4F6" android:layout_gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:id="@+id/tvReturned" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="14" android:textColor="@color/blue_royal" android:textSize="24sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/profile_returned" android:textColor="@color/text_secondary_light" android:textSize="12sp" />
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="40dp" android:background="#F3F4F6" android:layout_gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:id="@+id/tvReserved" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1" android:textColor="@color/blue_royal" android:textSize="24sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/profile_reservations" android:textColor="@color/text_secondary_light" android:textSize="12sp" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Seção de Metas -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="METAS DE LEITURA"
                    android:textColor="@color/text_secondary_light"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <ImageButton
                    android:id="@+id/btnAddGoal"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_input_add"
                    app:tint="@color/blue_royal"
                    android:contentDescription="Adicionar Meta" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvGoals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_reading_goal" />

            <!-- Multas -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                android:text="@string/profile_section_fines"
                android:textColor="@color/text_secondary_light"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F3F4F6">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_pending_label"
                        android:textColor="@color/text_secondary_light"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvTotalFine"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R$ 0,00"
                        android:textColor="@color/status_unavailable"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvFines"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Configurações -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                android:text="@string/profile_section_settings"
                android:textColor="@color/text_secondary_light"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F3F4F6">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include layout="@layout/item_menu_row" android:id="@+id/rowReadingHistory" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="56dp" android:background="#F3F4F6" />
                    <include layout="@layout/item_menu_row" android:id="@+id/rowReadingGoals" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="56dp" android:background="#F3F4F6" />
                    <include layout="@layout/item_menu_row" android:id="@+id/rowFines" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="56dp" android:background="#F3F4F6" />
                    <include layout="@layout/item_menu_row" android:id="@+id/rowChangePassword" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="56dp" android:background="#F3F4F6" />
                    <include layout="@layout/item_menu_row" android:id="@+id/rowLogout" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/btnEditProfile"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="32dp"
                android:text="Editar Perfil"
                android:textColor="@color/blue_royal"
                android:backgroundTint="@color/white"
                app:strokeColor="@color/blue_royal"
                app:strokeWidth="1dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="100dp" />
    </LinearLayout>
</ScrollView>